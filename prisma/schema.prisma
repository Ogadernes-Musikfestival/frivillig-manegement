// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Holdleder {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?

}

model Frivillig {
  id                String   @id @default(uuid())

  // Core contact info
  navn              String
  email             String
  telefon           String?

  // Preferences (soft wishes)
  onsketVagtMed     String?   // Free text: names, nicknames, social wishes
  onsketOmraade     Omraade?

  // Comments / human context
  kommentar         String?   // Notes, wishes, social info, anything relevant

  // Admin / system
  status            FrivilligStatus @default(TILMELDT)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum Omraade {
  HEGNVAGT
  KOKKEN
  LEGEPLADS
}

enum FrivilligStatus {
  TILMELDT
  GODKENDT
  AFVIST
  TILDELT_VAGT
}

